# PromptWeave Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/promptweave

# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=change-me-in-production
SESSION_STORE=memory  # memory | pg | redis

# Auth (Feishu OAuth - optional, set AUTH_DISABLED=true to skip)
AUTH_DISABLED=true
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ALLOWED_REDIRECTS=http://localhost:5173/auth/callback

# Admin
ADMIN_PASSWORD=

# Observability (optional)
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
